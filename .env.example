# ============================================
# Freebuff - Configuration des clés API
# ============================================
# Copie ce fichier en .env et remplis tes clés
# cp .env.example .env
# ============================================

# --- DeepSeek (gratuit, pas besoin de clé) ---
# Tu peux laisser vide, DeepSeek fonctionne sans clé
# DEEPSEEK_API_KEY=

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Anthropic Claude ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# --- Groq (modèles gratuits, ultra-rapides) ---
# https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# --- Ollama (local, pas besoin de clé) ---
# Laisse l'URL par défaut si Ollama tourne sur ta machine
# OLLAMA_URL=http://localhost:11434

# --- Port du serveur Freebuff (optionnel) ---
# PORT=7777
