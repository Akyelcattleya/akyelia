# ============================================
# AI FACTORY - Variables d'Environnement
# ============================================
# Renomme ce fichier en .env et modifie les valeurs
# cp ai-factory.env.template .env && nano .env
# ============================================

# --- Sécurité (genere des secrets aleatoires) ---
N8N_PASSWORD=changeme-maintenant
WEBUI_SECRET_KEY=change-moi-aussi

# --- Domaines (pour Caddy/SSL automatique) ---
DOMAIN_MAIN=votre-domaine.com
DOMAIN_OPENHANDS=openhands.votre-domaine.com
DOMAIN_N8N=n8n.votre-domaine.com
DOMAIN_CHAT=chat.votre-domaine.com

# --- Clés API (optionnelles - activent plus de providers) ---
# Laisse vide si tu utilises uniquement Ollama en local
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Ollama - Modele par defaut au demarrage ---
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:14b

# --- Browserless / Navigation ---
BROWSERLESS_TOKEN=
MAX_CONCURRENT_SESSIONS=5

# --- Qdrant ---
QDRANT_API_KEY=
