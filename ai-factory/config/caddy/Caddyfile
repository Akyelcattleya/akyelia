# ============================================
# AI FACTORY - Caddy v2 Configuration
# ============================================

:80 {
    # D'abord les requêtes API → Smart Router
    @api {
        path /api*
    }
    reverse_proxy @api smart-router:8765

    # Ensuite les fichiers statiques
    root * /srv
    try_files {path} /smart-terminal.html
    file_server
}
