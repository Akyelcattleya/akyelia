# ============================================
# AI FACTORY - Caddy Configuration
# ============================================
# Mode HTTP — Sert le portail + proxy tous les services
# ============================================

{
    # Évite les erreurs de certificat en HTTP
    local_certs
}

:80 {
    # Sert les fichiers statiques depuis /srv
    root * /srv
    
    # Portal — page d'accueil par défaut
    try_files portal.html /portal.html
    
    # Fichiers statiques
    file_server
    
    # ============================================
    # SMART ROUTER — Le chat unique avec routage IA
    # ============================================
    handle_path /api/* {
        reverse_proxy smart-router:8765
    }
    
    # ============================================
    # STATUT — Vérification santé
    # ============================================
    handle /status {
        header Content-Type "application/json"
        respond `{"status":"ok","version":"2.0","services":["openhands","webui","ollama","qdrant","n8n","browserless","smart-router"]}`
    }
    
    # Headers de sécurité
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
    
    # Compression
    encode gzip zstd
}

# ============================================
# Redirection HTTP vers HTTPS (si domaine)
# ============================================
